      m_Calls: []
  m_text: "A great place to start is a stacking pattern called 9\u20131.\n\nStack
    pieces in the left 9 columns and keep the rightmost column open as your \u201Cwell.\u201D\n\nOnly
    fill the well with an I piece when you can clear four lines at once (a Quad Clear).\n\nLater,
    we'll learn 6\u20133, a more advanced pattern that supports T-spins and other
    setups."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6af94fbdd2e124181a1892a853cdf440, type: 2}
  m_sharedMaterial: {fileID: -2504890859898317026, guid: 6af94fbdd2e124181a1892a853cdf440, type: 2}
