  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Stacking games are incredibly fun, and dangerously addictive.\n\nBut improving
    isn\u2019t always straightforward. Tips are scattered. Explanations are vague.
    And there\u2019s more going on than just stacking blocks and clearing lines.\n\nThere
    are rotation rules you won\u2019t find in basic tutorials. Stacking patterns
    and chaining mechanics that experienced players just seem to know.\n\nSo where
    do you actually learn and practice them? \n\nRight here.\n\nThis trainer will
    take you from beginner to dangerous \u2014 one piece at a time.\n\nLet\u2019s
    get started."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6af94fbdd2e124181a1892a853cdf440, type: 2}
