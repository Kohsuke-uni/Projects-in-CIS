      m_Calls: []
  m_text: 'Without going into too much detail about the rotation rules for all the
    pieces, it will suffice for now to say that you can "spin" a T piece into the
    T-shaped hole in two ways: clockwise and counter clockwise.


    Note: For the
    outside cases below you must have at least two blocks behind the T for it to
    "kick" into place. Otherwise it will rotate normally.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6af94fbdd2e124181a1892a853cdf440, type: 2}
  m_sharedMaterial: {fileID: -2504890859898317026, guid: 6af94fbdd2e124181a1892a853cdf440, type: 2}
