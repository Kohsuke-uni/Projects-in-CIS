  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Got the hang of 9\u20131 stacking?\n\nNow it\u2019s time to level up.\n\n6\u20133
    stacking divides the board into two sections. You stack in the first 6 columns,
    leave a controlled gap, and stack again in the last 3 columns.\n\nThis shape
    naturally creates structures that make T-spins easier to set up.\n\nT-spins score
    some of the highest points in modern Tetris and are essential for advanced play.\n\nNote:
    6\u20133 is harder to manage than 9\u20131.\nIf your stack becomes unstable,
    return to 9\u20131 to rebuild consistency."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6af94fbdd2e124181a1892a853cdf440, type: 2}
  m_sharedMaterial: {fileID: -2504890859898317026, guid: 6af94fbdd2e124181a1892a853cdf440, type: 2}
