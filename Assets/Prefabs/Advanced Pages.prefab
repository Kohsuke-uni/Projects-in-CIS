  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'T-Spin Triple clears 3 lines at once and scores the most points in modern
    Tetris.


    You need an F-shape with an overhang.


    The easiest way to
    form the base shape is with an L or J piece and a T.


    In the example to
    the right you can rotate the T piece cw to wedge it under the overhang and then
    cw again to "kick" it down into place.


    It''s easy to explain but difficult
    to master.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6af94fbdd2e124181a1892a853cdf440, type: 2}
  m_sharedMaterial: {fileID: -2504890859898317026, guid: 6af94fbdd2e124181a1892a853cdf440, type: 2}
