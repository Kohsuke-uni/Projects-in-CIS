      m_Calls: []
  m_text: 'The S and Z pieces can also "kick" off the wall.


    For the S piece
    you orient it by rotating it ccw to get it into position and then ccw again to
    kick it into place.


    For the Z piece you orient it by rotating it cw to
    get it into position and then cw again to kick it into place.


    Note: You
    must have a wall at least two pieces high, otherwise it will rotate normally.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6af94fbdd2e124181a1892a853cdf440, type: 2}
  m_sharedMaterial: {fileID: -2504890859898317026, guid: 6af94fbdd2e124181a1892a853cdf440, type: 2}
